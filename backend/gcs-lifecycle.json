{
  "rule": [
    {
      "action": { "type": "Delete" },
      "condition": {
        "age": 3,
        "matchesPrefix": ["contests/", "sessions/"]
      }
    },
    {
      "action": { "type": "Delete" },
      "condition": {
        "age": 11,
        "matchesPrefix": ["exports/"]
      }
    }
  ]
}
